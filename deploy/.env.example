# Mimir production server configuration.
# Copy to .env next to docker-compose.yml and fill in. chmod 600 .env

# --- Secrets (REQUIRED — install_server.sh generates these automatically) ---
POSTGRES_PASSWORD=change-me
MQTT_USER=mimir-display
MQTT_PASSWORD=change-me
MQTT_EXPOSE_CREDENTIALS=true

# --- Network identity (OPTIONAL for most setups) ---
# Mimir advertises itself as mimir.local on your LAN automatically via mDNS.
# You can open the web UI at http://mimir.local:8080 without setting anything here.
#
# Set PUBLIC_HOST only if mDNS doesn't work in your environment (e.g. you're on
# a separate VLAN from your displays, or some devices can't resolve .local names):
# PUBLIC_HOST=192.168.1.50
# MQTT_PUBLIC_HOST=192.168.1.50
# Must stay 1883 (authenticated LAN listener); 1884 is localhost-only.
MQTT_PUBLIC_PORT=1883

# --- Optional ---
# Override the mDNS hostname (default: mimir.local).
# PUBLIC_MDNS_HOST=mimir.local
# Shared secret between API and discovery service.
# MIMIR_DISCOVERY_TOKEN=
# Extra browser origins allowed by CORS (usually not needed).
# CORS_ORIGINS_EXTRA=
# Where uploads/channels persist on the host (default /opt/mimir/data).
# MIMIR_DATA_DIR=/opt/mimir/data
# Release channel to follow from versions.yml (default stable).
# MIMIR_CHANNEL=stable
